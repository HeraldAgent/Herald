# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── News Sources ─────────────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key   # free at cryptopanic.com/developers

# ─── Signal Filters ───────────────────────────────────────────────────────────
MIN_CONFIDENCE=0.65
MAX_SIGNALS_PER_CYCLE=5
SIGNAL_TTL_MS=3600000          # 1 hour

# ─── Scanner ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=300000        # 5 minutes
TRACKED_TOKENS=SOL,BTC,ETH,JTO,AAVE,JUP,BONK,WIF,PYTH,RENDER

# ─── Model ───────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
